    pokemon:captureRate          45 ;
    pokemon:esHabilidadOculta    false ;
    pokemon:tieneTipoPrimario    pokemon:Fire ;
    pokemon:disponibleEnRegion   pokemon:Kanto ;
    pokemon:perteneceAGeneración pokemon:Gen1 ;
    pokemon:perteneceAEggGroup   pokemon:EG_Monster ;
    pokemon:tieneCurvaExperiencia pokemon:CurvaMediumSlow ;
    pokemon:viveEnHabitat        pokemon:HabGrassland ;
    pokemon:tieneHabilidad       pokemon:Blaze ;
    pokemon:tieneColor           pokemon:ColorRed ;
    pokemon:tieneFormaCorporal   pokemon:FormaUpright .

pokemon:Squirtle a pokemon:Pokemon ;
    pokemon:nombreForma          "Squirtle" ;
    pokemon:hp                   44 ;
