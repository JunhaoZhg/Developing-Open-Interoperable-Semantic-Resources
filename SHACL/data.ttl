    pokemon:tieneHabilidad       pokemon:Torrent ;
    pokemon:tieneColor           pokemon:ColorBlue ;
    pokemon:tieneFormaCorporal   pokemon:FormaUpright .

# A region different from the dataset's Kalos: needed for value-class coverage.
pokemon:Kalos  a pokemon:Region ; pokemon:nombreRegion "Kalos" .

