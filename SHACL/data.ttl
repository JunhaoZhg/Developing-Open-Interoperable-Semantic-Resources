@prefix pokemon: <http://example.org/pokemon#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .

# Tipos (types) 
pokemon:Grass     a pokemon:Tipo ; pokemon:nombreTipo "Grass" .
pokemon:Poison    a pokemon:Tipo ; pokemon:nombreTipo "Poison" .
pokemon:Fire      a pokemon:Tipo ; pokemon:nombreTipo "Fire" .
pokemon:Water     a pokemon:Tipo ; pokemon:nombreTipo "Water" .
pokemon:Electric  a pokemon:Tipo ; pokemon:nombreTipo "Electric" .
pokemon:Flying    a pokemon:Tipo ; pokemon:nombreTipo "Flying" .
pokemon:Dragon    a pokemon:Tipo ; pokemon:nombreTipo "Dragon" .
pokemon:Psychic   a pokemon:Tipo ; pokemon:nombreTipo "Psychic" .

# Regiones 
pokemon:Kanto  a pokemon:Region ; pokemon:nombreRegion "Kanto" .
pokemon:Johto  a pokemon:Region ; pokemon:nombreRegion "Johto" .
pokemon:Hoenn  a pokemon:Region ; pokemon:nombreRegion "Hoenn" .
pokemon:Sinnoh a pokemon:Region ; pokemon:nombreRegion "Sinnoh" .

# An INVALID region: "Orre" is not in the allowed enumeration.
pokemon:Orre   a pokemon:Region ; pokemon:nombreRegion "Orre" .

# --- Generaciones ---
pokemon:Gen1 a pokemon:Generacion ; pokemon:numeroGeneracion 1 .
pokemon:Gen2 a pokemon:Generacion ; pokemon:numeroGeneracion 2 .
pokemon:Gen3 a pokemon:Generacion ; pokemon:numeroGeneracion 3 .
pokemon:Gen6 a pokemon:Generacion ; pokemon:numeroGeneracion 6 .
pokemon:Gen7 a pokemon:Generacion ; pokemon:numeroGeneracion 7 .

# An INVALID generation: 9 is outside [1,7].
pokemon:Gen9 a pokemon:Generacion ; pokemon:numeroGeneracion 9 .

# EggGroups
pokemon:EG_Monster a pokemon:EggGroup ; pokemon:nombreEggGroup "Monster" .
pokemon:EG_Grass   a pokemon:EggGroup ; pokemon:nombreEggGroup "Grass" .
pokemon:EG_Field   a pokemon:EggGroup ; pokemon:nombreEggGroup "Field" .
pokemon:EG_Dragon  a pokemon:EggGroup ; pokemon:nombreEggGroup "Dragon" .

# Curvas de experiencia
pokemon:CurvaMediumSlow a pokemon:CurvaDeExperiencia ; pokemon:nombreCurva "Medium Slow" .
pokemon:CurvaMediumFast a pokemon:CurvaDeExperiencia ; pokemon:nombreCurva "Medium Fast" .
pokemon:CurvaSlow       a pokemon:CurvaDeExperiencia ; pokemon:nombreCurva "Slow" .

# Hábitats
pokemon:HabGrassland   a pokemon:Habitat ; pokemon:nombreHabitat "grassland" .
pokemon:HabForest      a pokemon:Habitat ; pokemon:nombreHabitat "forest" .
pokemon:HabCave        a pokemon:Habitat ; pokemon:nombreHabitat "cave" .
pokemon:HabUrban       a pokemon:Habitat ; pokemon:nombreHabitat "urban" .

# Habilidades
pokemon:Overgrow   a pokemon:Habilidad ; pokemon:nombreHabilidad "Overgrow" .
pokemon:Blaze      a pokemon:Habilidad ; pokemon:nombreHabilidad "Blaze" .
pokemon:Torrent    a pokemon:Habilidad ; pokemon:nombreHabilidad "Torrent" .
pokemon:Chlorophyll a pokemon:Habilidad ; pokemon:nombreHabilidad "Chlorophyll" .
pokemon:Static     a pokemon:Habilidad ; pokemon:nombreHabilidad "Static" .

# Colores 
pokemon:ColorGreen  a pokemon:Color ; pokemon:nombreColor "green" .
pokemon:ColorRed    a pokemon:Color ; pokemon:nombreColor "red" .
pokemon:ColorBlue   a pokemon:Color ; pokemon:nombreColor "blue" .
pokemon:ColorYellow a pokemon:Color ; pokemon:nombreColor "yellow" .

# An INVALID color: "magenta" is not in the closed enumeration.
pokemon:ColorMagenta a pokemon:Color ; pokemon:nombreColor "magenta" .

# Formas corporales 
pokemon:FormaQuadruped a pokemon:FormaCorporal ; pokemon:nombreFormaCorp "quadruped" .
pokemon:FormaUpright   a pokemon:FormaCorporal ; pokemon:nombreFormaCorp "upright" .
pokemon:FormaWings     a pokemon:FormaCorporal ; pokemon:nombreFormaCorp "wings" .
pokemon:FormaBugWings  a pokemon:FormaCorporal ; pokemon:nombreFormaCorp "bug-wings" .



# CONFORMANT POKÉMON  -- should NOT trigger any violation
pokemon:Bulbasaur a pokemon:Pokemon ;
    pokemon:nombreForma          "Bulbasaur" ;
    pokemon:hp                   45 ;
    pokemon:attack               49 ;
    pokemon:defense              49 ;
    pokemon:spAtk                65 ;
    pokemon:spDef                65 ;
    pokemon:speed                45 ;
    pokemon:baseTotal            318 ;     # 45+49+49+65+65+45 = 318  ✓
    pokemon:captureRate          45 ;
    pokemon:esHabilidadOculta    false ;
    pokemon:tieneTipoPrimario    pokemon:Grass ;
    pokemon:tieneTipoSecundario  pokemon:Poison ;
    pokemon:disponibleEnRegion   pokemon:Kanto ;
    pokemon:perteneceAGeneración pokemon:Gen1 ;
    pokemon:perteneceAEggGroup   pokemon:EG_Monster ;
    pokemon:tieneCurvaExperiencia pokemon:CurvaMediumSlow ;
    pokemon:viveEnHabitat        pokemon:HabGrassland ;
    pokemon:tieneHabilidad       pokemon:Overgrow ;
    pokemon:tieneColor           pokemon:ColorGreen ;
    pokemon:tieneFormaCorporal   pokemon:FormaQuadruped .

pokemon:Charmander a pokemon:Pokemon ;
    pokemon:nombreForma          "Charmander" ;
    pokemon:hp                   39 ;
