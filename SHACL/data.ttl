pokemon:Greninja a pokemon:Pokemon ;
    pokemon:nombreForma          "Greninja" ;
    pokemon:hp                   72 ;
    pokemon:attack               95 ;
    pokemon:defense              67 ;
    pokemon:spAtk                103 ;
    pokemon:spDef                71 ;
