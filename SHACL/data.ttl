# NON-CONFORMANT POKÉMON  -- each one breaks ONE shape
# --- B1. Violates PokemonShape: hp out of range (300 > 255) ---
pokemon:Bad_HP_OutOfRange a pokemon:Pokemon ;
    pokemon:nombreForma          "BadHpPokemon" ;
    pokemon:hp                   300 ;          # violates sh:maxInclusive 255
    pokemon:attack               50 ;
    pokemon:defense              50 ;
    pokemon:spAtk                50 ;
    pokemon:spDef                50 ;
    pokemon:speed                50 ;
    pokemon:baseTotal            550 ;
    pokemon:captureRate          100 ;
    pokemon:esHabilidadOculta    false ;
    pokemon:tieneTipoPrimario    pokemon:Fire ;
    pokemon:tieneColor           pokemon:ColorRed .

# --- B2. Violates PokemonShape: attack has wrong datatype (string instead of integer) ---
pokemon:Bad_Attack_DatatypeWrong a pokemon:Pokemon ;
    pokemon:nombreForma          "BadAttackPokemon" ;
    pokemon:hp                   50 ;
    pokemon:attack               "fifty" ;       # violates sh:datatype xsd:integer
    pokemon:defense              50 ;
    pokemon:spAtk                50 ;
    pokemon:spDef                50 ;
    pokemon:speed                50 ;
    pokemon:baseTotal            300 ;
    pokemon:captureRate          100 ;
    pokemon:esHabilidadOculta    false ;
    pokemon:tieneTipoPrimario    pokemon:Fire ;
    pokemon:tieneColor           pokemon:ColorRed .

# --- B3. Violates PokemonShape: missing speed (minCount 1) ---
pokemon:Bad_MissingSpeed a pokemon:Pokemon ;
    pokemon:nombreForma          "BadMissingSpeed" ;
    pokemon:hp                   50 ;
    pokemon:attack               50 ;
    pokemon:defense              50 ;
    pokemon:spAtk                50 ;
    pokemon:spDef                50 ;
    # speed is intentionally omitted          # violates sh:minCount 1
    pokemon:baseTotal            250 ;
    pokemon:captureRate          100 ;
    pokemon:esHabilidadOculta    false ;
    pokemon:tieneTipoPrimario    pokemon:Fire ;
    pokemon:tieneColor           pokemon:ColorRed .

# --- B4. Violates PokemonTypeShape: missing primary type ---
pokemon:Bad_NoPrimaryType a pokemon:Pokemon ;
    pokemon:nombreForma          "BadNoPrimaryType" ;
    pokemon:hp                   50 ;
    pokemon:attack               50 ;
    pokemon:defense              50 ;
    pokemon:spAtk                50 ;
    pokemon:spDef                50 ;
    pokemon:speed                50 ;
    pokemon:baseTotal            300 ;
    pokemon:captureRate          100 ;
    pokemon:esHabilidadOculta    false ;
    # tieneTipoPrimario intentionally omitted violates sh:minCount 1
    pokemon:tieneColor           pokemon:ColorRed .

# --- B5. Violates PokemonTypeShape: two primary types (maxCount 1) ---
pokemon:Bad_TwoPrimaryTypes a pokemon:Pokemon ;
    pokemon:nombreForma          "BadTwoPrimary" ;
    pokemon:hp                   50 ;
    pokemon:attack               50 ;
    pokemon:defense              50 ;
    pokemon:spAtk                50 ;
    pokemon:spDef                50 ;
    pokemon:speed                50 ;
    pokemon:baseTotal            300 ;
    pokemon:captureRate          100 ;
    pokemon:esHabilidadOculta    false ;
    pokemon:tieneTipoPrimario    pokemon:Fire , pokemon:Water ;   # violates sh:maxCount 1
    pokemon:tieneColor           pokemon:ColorRed .

# --- B6. Violates PokemonHiddenAbilityShape: wrong datatype (string, not boolean) ---
pokemon:Bad_HiddenAbility_NotBoolean a pokemon:Pokemon ;
    pokemon:nombreForma          "BadHiddenAbility" ;
    pokemon:hp                   50 ;
    pokemon:attack               50 ;
    pokemon:defense              50 ;
    pokemon:spAtk                50 ;
    pokemon:spDef                50 ;
    pokemon:speed                50 ;
    pokemon:baseTotal            300 ;
    pokemon:captureRate          100 ;
    pokemon:esHabilidadOculta    "yes" ;          # violates sh:datatype xsd:boolean
    pokemon:tieneTipoPrimario    pokemon:Fire ;
    pokemon:tieneColor           pokemon:ColorRed .

# --- B7. Violates PokemonNameShape: name starts in lowercase + invalid character ---
pokemon:Bad_NameLowercase a pokemon:Pokemon ;
    pokemon:nombreForma          "bad_name!" ;   # lowercase first char + '_' '!' not allowed
    pokemon:hp                   50 ;
    pokemon:attack               50 ;
    pokemon:defense              50 ;
    pokemon:spAtk                50 ;
    pokemon:spDef                50 ;
    pokemon:speed                50 ;
    pokemon:baseTotal            300 ;
    pokemon:captureRate          100 ;
    pokemon:esHabilidadOculta    false ;
    pokemon:tieneTipoPrimario    pokemon:Fire ;
    pokemon:tieneColor           pokemon:ColorRed .

# --- B8. Violates PokemonBaseTotalShape (SPARQL): baseTotal does NOT match the sum
#         hp+attack+defense+spAtk+spDef+speed = 60+60+60+60+60+60 = 360, not 999 ---
pokemon:Bad_BaseTotalSum a pokemon:Pokemon ;
    pokemon:nombreForma          "BadBaseTotalSum" ;
    pokemon:hp                   60 ;
    pokemon:attack               60 ;
    pokemon:defense              60 ;
    pokemon:spAtk                60 ;
    pokemon:spDef                60 ;
    pokemon:speed                60 ;
    pokemon:baseTotal            999 ;            # should be 360
    pokemon:captureRate          100 ;
    pokemon:esHabilidadOculta    false ;
    pokemon:tieneTipoPrimario    pokemon:Fire ;
    pokemon:tieneColor           pokemon:ColorRed .

# --- B9. Violates RegionShape: triggered indirectly via pokemon:Orre defined above ---
#     (pokemon:Orre is an instance of pokemon:Region with nombreRegion "Orre",
#      which is NOT in the closed list).
# Pokémon used for completeness:
pokemon:Bad_PokemonInOrre a pokemon:Pokemon ;
    pokemon:nombreForma          "BadOrrePokemon" ;
    pokemon:hp                   50 ;
    pokemon:attack               50 ;
    pokemon:defense              50 ;
    pokemon:spAtk                50 ;
    pokemon:spDef                50 ;
    pokemon:speed                50 ;
    pokemon:baseTotal            300 ;
    pokemon:captureRate          100 ;
    pokemon:esHabilidadOculta    false ;
    pokemon:tieneTipoPrimario    pokemon:Fire ;
    pokemon:disponibleEnRegion   pokemon:Orre ;       # invalid region (already flagged by RegionShape)
    pokemon:tieneColor           pokemon:ColorRed .

# --- B10. Violates GenerationShape: triggered via pokemon:Gen9 (numeroGeneracion = 9 > 7) ---
pokemon:Bad_PokemonGen9 a pokemon:Pokemon ;
    pokemon:nombreForma          "BadGen9Pokemon" ;
    pokemon:hp                   50 ;
    pokemon:attack               50 ;
    pokemon:defense              50 ;
    pokemon:spAtk                50 ;
    pokemon:spDef                50 ;
    pokemon:speed                50 ;
    pokemon:baseTotal            300 ;
    pokemon:captureRate          100 ;
    pokemon:esHabilidadOculta    false ;
    pokemon:tieneTipoPrimario    pokemon:Fire ;
    pokemon:perteneceAGeneración pokemon:Gen9 ;       # invalid generation (already flagged by GenerationShape)
    pokemon:tieneColor           pokemon:ColorRed .

# --- B11. Violates ColorShape: triggered via pokemon:ColorMagenta defined above
#          ("magenta" not in the closed enumeration). Pokémon for context: ---
pokemon:Bad_PokemonMagenta a pokemon:Pokemon ;
    pokemon:nombreForma          "BadMagentaPokemon" ;
    pokemon:hp                   50 ;
    pokemon:attack               50 ;
    pokemon:defense              50 ;
    pokemon:spAtk                50 ;
    pokemon:spDef                50 ;
    pokemon:speed                50 ;
    pokemon:baseTotal            300 ;
    pokemon:captureRate          100 ;
    pokemon:esHabilidadOculta    false ;
    pokemon:tieneTipoPrimario    pokemon:Fire ;
    pokemon:tieneColor           pokemon:ColorMagenta .

# --- B12. Violates CaptureRateShape: captureRate = 500 (out of [3,255]) ---
pokemon:Bad_CaptureRateOutOfRange a pokemon:Pokemon ;
    pokemon:nombreForma          "BadCaptureRate" ;
    pokemon:hp                   50 ;
    pokemon:attack               50 ;
    pokemon:defense              50 ;
    pokemon:spAtk                50 ;
    pokemon:spDef                50 ;
    pokemon:speed                50 ;
    pokemon:baseTotal            300 ;
    pokemon:captureRate          500 ;            # violates sh:maxInclusive 255
    pokemon:esHabilidadOculta    false ;
    pokemon:tieneTipoPrimario    pokemon:Fire ;
    pokemon:tieneColor           pokemon:ColorRed .

# --- B13. Violates PokemonHabitatShape: viveEnHabitat points to a literal/non-Habitat resource ---
pokemon:Bad_HabitatNotHabitat a pokemon:Pokemon ;
    pokemon:nombreForma          "BadHabitatPokemon" ;
    pokemon:hp                   50 ;
    pokemon:attack               50 ;
    pokemon:defense              50 ;
    pokemon:spAtk                50 ;
    pokemon:spDef                50 ;
    pokemon:speed                50 ;
    pokemon:baseTotal            300 ;
    pokemon:captureRate          100 ;
    pokemon:esHabilidadOculta    false ;
    pokemon:tieneTipoPrimario    pokemon:Fire ;
    pokemon:viveEnHabitat        pokemon:Grass ;   # pokemon:Grass is a Tipo, not a Habitat
    pokemon:tieneColor           pokemon:ColorRed .
